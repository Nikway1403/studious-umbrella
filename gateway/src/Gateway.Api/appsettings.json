{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GrpcOptions": {
    "AuthServiceUrl": "http://localhost:5030"
  },
  "ReverseProxy": {
    "Routes": {
      "voice-route": {
        "ClusterId": "voice-cluster",
        "Match": {
          "Path": "/voice/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "voice-cluster": {
        "Destinations": {
          "voice-service": {
            "Address": "http://localhost:5002/"
          }
        }
      }
    }
  }
}
